// Schema do banco de dados do HackPerfil — HACK SCHOOL®
// Pensado para rodar em PostgreSQL (Vercel Postgres, Neon, Supabase, etc.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  CREATOR
  BUILDER
  CONNECTOR
  TECH_MAKER
  LEADER
}

enum Role {
  ALUNO
  PROFESSOR
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  escola       String?
  serie        String?
  role         Role         @default(ALUNO)
  createdAt    DateTime     @default(now())
  results      TestResult[]

  turmaId      String?
  turma        Turma?   @relation("AlunosDaTurma", fields: [turmaId], references: [id])
  numeroEquipe Int?

  turmasCriadas Turma[] @relation("ProfessorDaTurma")
}

model TestResult {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfil      Perfil
  scoreCreator   Int
  scoreBuilder   Int
  scoreConnector Int
  scoreTechMaker Int
  scoreLeader    Int
  answers     Json
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Turma {
  id          String   @id @default(cuid())
  nome        String
  codigo      String   @unique
  createdAt   DateTime @default(now())

  professorId String
  professor   User     @relation("ProfessorDaTurma", fields: [professorId], references: [id], onDelete: Cascade)

  alunos      User[]   @relation("AlunosDaTurma")

  @@index([professorId])
}
